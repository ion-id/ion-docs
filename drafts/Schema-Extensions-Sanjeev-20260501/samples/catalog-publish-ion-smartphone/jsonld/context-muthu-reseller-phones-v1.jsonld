      },
      "batteryHealthPercent": {
        "@id": "muthu:batteryHealthPercent",
        "@type": "xsd:integer"
      },
      "schema": "https://schema.org/",
      "itemCondition": {
        "@id": "schema:itemCondition",
        "@type": "@id"
      },
      "xsd": "http://www.w3.org/2001/XMLSchema#"
    }
  ]
